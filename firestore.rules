// ============================================================
// WINN Platforms — Firestore Security Rules
//
// Deploy via: firebase deploy --only firestore:rules
// Or paste directly in Firebase Console → Firestore → Rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helper functions ----

    // Is the request from an authenticated user?
    function isAuth() {
      return request.auth != null;
    }

    // Fetch the caller's role from the users collection (safe if doc missing)
    function callerRole() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(path)
        ? 'guest'
        : get(path).data.get('role', 'regular');
    }

    // Role hierarchy check: caller's role must be >= required
    // Roles: guest(0) < regular(1) < moderator(2) < admin(3)
    // Accepts lowercase or capitalized role (e.g. "admin" or "Admin")
    function hasRole(required) {
      let rank = {'guest': 0, 'regular': 1, 'moderator': 2, 'Moderator': 2, 'admin': 3, 'Admin': 3};
      let role = callerRole();
      return isAuth() && role in rank && required in rank && rank[role] >= rank[required];
    }

    // Is the caller the owner of the document?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }


    // ---- /users/{uid} ----
    match /users/{uid} {
      // Anyone authenticated can read user profiles
      allow read: if isAuth();

      // A user can create their own document (registration)
      // They may NOT set themselves a privileged role
      allow create: if isOwner(uid)
        && request.resource.data.role == 'regular'
        && request.resource.data.email == request.auth.token.email;

      // A user can update their own displayName only
      // Role changes are admin-only
      allow update: if
        // Own profile: only displayName allowed
        (isOwner(uid)
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email)
        ||
        // Admin can update anything
        hasRole('admin');

      // Only admin can delete user documents
      allow delete: if hasRole('admin');
    }


    // ---- /announcements/{id} ----
    match /announcements/{id} {
      // Everyone (including unauthenticated) can read
      allow read: if true;

      // Only moderators and admins can create
      allow create: if hasRole('moderator')
        && request.resource.data.authorUid == request.auth.uid;

      // Only the author (if mod+) or an admin can update
      allow update: if hasRole('admin');

      // Moderator+ can delete any announcement; author can delete their own
      allow delete: if hasRole('moderator')
        || (isAuth() && resource.data.authorUid == request.auth.uid && hasRole('moderator'));
    }


    // ---- /forum_posts/{id} ----
    match /forum_posts/{id} {
      // Everyone can read forum posts
      allow read: if true;

      // Registered users (regular+) can create posts
      allow create: if hasRole('regular')
        && request.resource.data.authorUid == request.auth.uid;

      // Authors can update their own post; moderators/admins can update any
      allow update: if (isOwner(resource.data.authorUid) && hasRole('regular'))
        || hasRole('moderator');

      // Moderators can delete any post; authors can delete their own
      allow delete: if hasRole('moderator')
        || isOwner(resource.data.authorUid);
    }


    // ---- /forum_posts/{postId}/comments/{cid} ----
    match /forum_posts/{postId}/comments/{cid} {
      allow read: if true;
      allow create: if hasRole('regular')
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if (isOwner(resource.data.authorUid) && hasRole('regular'))
        || hasRole('admin');
      allow delete: if hasRole('admin') || isOwner(resource.data.authorUid);
    }


    // ---- /writing_posts/{postId}/comments/{cid} ----
    match /writing_posts/{postId}/comments/{cid} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if isOwner(resource.data.authorUid) || hasRole('admin');
      allow delete: if hasRole('admin') || isOwner(resource.data.authorUid);
    }


    // ---- /news_posts/{postId}/comments/{cid} ----
    match /news_posts/{postId}/comments/{cid} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if isOwner(resource.data.authorUid) || hasRole('admin');
      allow delete: if hasRole('admin') || isOwner(resource.data.authorUid);
    }


    // ---- /discussion_posts/{id} ----
    match /discussion_posts/{id} {
      // Everyone can read
      allow read: if true;

      // Registered users can create
      allow create: if hasRole('regular')
        && request.resource.data.authorUid == request.auth.uid;

      // Authors can edit their own post; moderators/admins can edit any
      allow update: if (isOwner(resource.data.authorUid) && hasRole('regular'))
        || hasRole('moderator');

      // Moderators can delete any; authors can delete their own
      allow delete: if hasRole('moderator')
        || isOwner(resource.data.authorUid);
    }


    // ---- /news_posts/{id} ----
    match /news_posts/{id} {
      // Everyone (including unauthenticated) can read published posts
      allow read: if true;

      // Only moderators and admins can create news posts
      allow create: if hasRole('moderator')
        && request.resource.data.authorUid == request.auth.uid;

      // Anyone can increment/decrement likeCount only;
      // author (mod+) or admin can update any field
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount'])
        || (isOwner(resource.data.authorUid) && hasRole('moderator'))
        || hasRole('admin');

      // Moderator+ can delete any; author can delete their own
      allow delete: if hasRole('moderator')
        || (isAuth() && resource.data.authorUid == request.auth.uid && hasRole('moderator'));
    }


    // ---- /writing_posts/{id} ----
    match /writing_posts/{id} {
      // Everyone can read
      allow read: if true;

      // Only moderators and admins can create writing posts
      allow create: if hasRole('moderator')
        && request.resource.data.authorUid == request.auth.uid;

      // Authors can update their own post; admins can update any
      allow update: if (isOwner(resource.data.authorUid) && hasRole('moderator'))
        || hasRole('admin');

      // Moderators can delete any; authors can delete their own
      allow delete: if hasRole('moderator')
        || isOwner(resource.data.authorUid);
    }


    // ---- /consultation_slots/{id} ----
    match /consultation_slots/{id} {
      // Authenticated users can read slots
      allow read: if isAuth();
      // Only admin can manage slots
      allow create, update, delete: if hasRole('admin');
    }


    // ---- /consultations/{id} ----
    match /consultations/{id} {
      // Admin sees all; requester sees their own
      allow read: if hasRole('admin')
        || (isAuth() && resource.data.requesterUid == request.auth.uid);
      // Authenticated users can create for themselves only
      allow create: if isAuth()
        && request.resource.data.requesterUid == request.auth.uid;
      // Only admin can update (approve/reject)
      allow update: if hasRole('admin');
      // Admin or the requester can delete
      allow delete: if hasRole('admin')
        || isOwner(resource.data.requesterUid);
    }


    // ---- /software_projects/{id} ----
    match /software_projects/{id} {
      allow read: if true;
      allow create, update, delete: if hasRole('admin');
    }


    // ---- /design_projects/{id} ----
    match /design_projects/{id} {
      allow read: if true;
      allow create, update, delete: if hasRole('admin');
    }


    // ---- /site_config/{docId} ----
    // Public site configuration (profile, collaborators, etc.)
    match /site_config/{docId} {
      allow read: if true;
      allow write: if hasRole('admin');
    }


    // ---- /visits/{id} ----
    // Anyone can log a visit; only admins can read stats
    match /visits/{id} {
      allow create: if true;
      allow read:   if hasRole('admin');
      allow update, delete: if false;
    }


    // ---- Deny all other paths ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
