rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Legacy: inline images attached to old posts
    match /post-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Inline editor media (images, video, audio embedded in rich-text body)
    match /editor-media/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 100 * 1024 * 1024;  // 100 MB max
    }

    // Post thumbnails
    match /thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // General file attachments
    match /attachments/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;  // 25 MB max
    }

    // Profile photo (admin only write)
    match /profile/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
